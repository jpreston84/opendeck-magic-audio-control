{
  "Name": "Magic Audio Control",
  "Description": "Control audio streams - cycle through playing audio sources and adjust volume",
  "Author": "Jonathan Preston",
  "Version": "0.1.0",
  "Category": "Audio",
  "Icon": "icons/plugin",
  "CodePath": "x86_64-unknown-linux-gnu/bin/open-deck-audio-control",
  "CodePaths": {
    "x86_64-unknown-linux-gnu": "x86_64-unknown-linux-gnu/bin/open-deck-audio-control"
  },
  "CodePathLin": "x86_64-unknown-linux-gnu/bin/open-deck-audio-control",
  "OS": [
    { "Platform": "linux" }
  ],
  "Actions": [
    {
      "Name": "Cycle Audio Stream",
      "UUID": "net.jpreston.opendeck.audio.cycle-stream",
      "Icon": "icons/cycle-stream",
      "Tooltip": "Cycles through active audio streams",
      "Controllers": ["Keypad"],
      "States": [
        {
          "Image": "icons/cycle-stream",
          "FontSize": 14
        }
      ],
      "SupportedInMultiActions": true,
      "PropertyInspectorPath": "propertyInspector/cycleAudioStream.html"
    },
    {
      "Name": "Volume Control",
      "UUID": "net.jpreston.opendeck.audio.volume-control",
      "Icon": "icons/volume-knob",
      "Tooltip": "Rotate to adjust volume of selected stream",
      "Controllers": ["Encoder"],
      "States": [
        {
          "Image": "icons/volume-knob",
          "FontSize": 16
        }
      ],
      "SupportedInMultiActions": true,
      "PropertyInspectorPath": "propertyInspector/volumeControl.html"
    }
  ]
}
